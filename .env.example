# ── Hermes Agent Team — environment configuration ──────────────────
# Copy to .env and fill in values for your deployment.

# Hermes profiles 根目录
HERMES_HOME=~/.hermes

# Agent 工作区根目录（每个 profile 的工作目录会建在这下面）
AGENT_TEAM_WORKSPACE_ROOT=~/agent_team

# 数据库连接串（默认 SQLite，文件位于 data/hermes_agent_team.db）
# DATABASE_URL=sqlite:///data/hermes_agent_team.db

# Agent 通过 MCP 连回中枢的地址
HERMES_AGENTS_MCP_URL=http://127.0.0.1:5050/mcp/

# HTTP 服务端口
PORT=5050

# 调试模式（1 开启自动 reload，0 生产模式）
FLASK_DEBUG=1

# ── Security ─────────────────────────────────────────────────────

# Application secret key for internal signing.
# Required in production (FLASK_DEBUG=0). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# API authentication token. When set, all API endpoints (except health
# check) require this token via X-API-Key or Authorization: Bearer header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# API_TOKEN=

# CORS allowed origins (comma-separated). In debug mode, defaults to *.
# In production, set explicitly. Example:
# CORS_ORIGINS=https://dashboard.example.com,https://admin.example.com

# ── Rate limiting ─────────────────────────────────────────────────

# Max requests per window per client IP. Set to 0 to disable.
# RATE_LIMIT_MAX=300
# RATE_LIMIT_WINDOW=60  (seconds)

# ── Docker secrets ───────────────────────────────────────────────
# When deploying with Docker Compose or Swarm, place secret files
# in /run/secrets/ and they will be loaded automatically.
# E.g., a file at /run/secrets/SECRET_KEY sets the SECRET_KEY variable.

# ── Logging ───────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
# Log format: text (human-readable) or json (structured)
# LOG_FORMAT=text
# Log directory for file output. If unset, logs go to console.
# LOG_DIR=/var/log/hermes-agent-team

# ── Self-evolving learning ────────────────────────────────────────

# Enable/disable the learning engine (1=on, 0=off)
# LEARN_ENABLED=1
# Embedding provider for semantic memory search (ollama or leave empty for fallback)
# LEARN_EMBED_PROVIDER=ollama
# LEARN_EMBED_MODEL=nomic-embed-text
